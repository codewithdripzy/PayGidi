
# Application mode
APP_ENV=development
GRPC_PORT=50055
HTTP_PORT=8081

# Squad Configuration
SQUAD_API_URL=https://sandbox-api-d.squadco.com
SQUAD_SECRET_KEY=

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
